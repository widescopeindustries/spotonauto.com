{
  "name": "spotonauto-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node --experimental-strip-types scripts/content-integrity-check.mjs && node --experimental-strip-types scripts/generate-repair-sitemaps.mjs && node scripts/generate-wiring-sitemaps.mjs",
    "build": "next build --webpack",
    "prestart": "node --experimental-strip-types scripts/generate-repair-sitemaps.mjs && node scripts/generate-wiring-sitemaps.mjs",
    "start": "(sleep 30 && node scripts/submit-indexnow.js >/tmp/spotonauto-indexnow.log 2>&1) & next start",
    "lint": "eslint src next.config.js",
    "typecheck": "tsc --noEmit",
    "analytics:recovery": "node scripts/recovery-scoreboard.js",
    "analytics:command-centers": "node scripts/command-center-opportunities.js",
    "analytics:backbone": "node --experimental-strip-types scripts/manual-backbone-scoreboard.ts",
    "analytics:wiring": "node scripts/wiring-analytics-report.js",
    "analytics:graph": "node scripts/graph-analytics-report.js",
    "analytics:graph-priority": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/graph-priority-report.ts",
    "analytics:graph-dimensions": "node scripts/ensure-graph-ga4-dimensions.js",
    "analytics:graph-dimensions:create": "node scripts/ensure-graph-ga4-dimensions.js --create-missing",
    "analytics:graph-scoreboard": "node scripts/graph-scoreboard.js",
    "analytics:graph-apply": "node scripts/graph-scoreboard.js --apply-live",
    "analytics:lost-pages": "node scripts/lost-pages-report.js",
    "analytics:indexing-trust": "node scripts/indexing-trust-monitor.js",
    "health:manual-backbone": "node --experimental-strip-types scripts/manual-backbone-health.ts",
    "index:manual-backbone": "node --experimental-strip-types scripts/index-lmdb-vectors.ts",
    "audit:internal-links": "node scripts/internal-link-audit.js",
    "audit:knowledge-graph": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/audit-knowledge-graph.ts",
    "seo:graph-link-suggestions": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/generate-graph-link-suggestions.ts",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "smoke:local": "BASE_URL=http://localhost:3000 node scripts/smoke-prod.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.20.0",
    "@supabase/supabase-js": "^2.90.0",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.25",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.3.0",
    "lucide-react": "^0.556.0",
    "next": "^16.1.4",
    "openai": "^6.22.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-webcam": "^7.2.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-bluetooth": "^0.0.21",
    "cheerio": "^1.2.0",
    "critters": "^0.0.23",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "lmdb": "^3.2.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
