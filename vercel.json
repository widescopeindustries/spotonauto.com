{
  "framework": "nextjs",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.alloemmanuals.com"
        }
      ],
      "destination": "https://alloemmanuals.com/$1",
      "permanent": true
    }
  ]
}
