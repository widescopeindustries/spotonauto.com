# Local Postgres Configuration
DATABASE_URL=postgresql://spotonauto:your-password@127.0.0.1:5432/spotonauto
LOCAL_DATABASE_URL=postgresql://spotonauto:your-password@127.0.0.1:5432/spotonauto

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_... (or sk_live_... for production)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Payment Links - Create these in your Stripe Dashboard
# Go to: https://dashboard.stripe.com/payment-links
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_LINK=https://buy.stripe.com/cNi14na6t8iycykeo718c08
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_LINK=https://buy.stripe.com/test_...
NEXT_PUBLIC_STRIPE_PRO_PLUS_MONTHLY_LINK=https://buy.stripe.com/test_...
NEXT_PUBLIC_STRIPE_PRO_PLUS_ANNUAL_LINK=https://buy.stripe.com/test_...

# Gemini AI API Key
GEMINI_API_KEY=your-gemini-api-key

# Amazon Associates
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=aiautorepair-20

# Optional: PostHog Analytics
# NEXT_PUBLIC_POSTHOG_KEY=...
# NEXT_PUBLIC_POSTHOG_HOST=...

# Graph Backbone Gateway
GRAPH_BACKBONE_GATEWAY_ENABLED=true
GRAPH_BACKEND_BASE_URL=http://116.202.210.109/graph-backbone
GRAPH_BUILD_ROOT=/data/lemon-manuals/graph-backbone

# AI bot monetization enforcement
# TollBit host that receives forwarded paywall-capable bot traffic.
TOLLBIT_HOST=tollbit.alloemmanuals.com
# Comma-separated UA fragments to forward to TollBit.
TOLLBIT_FORWARD_BOTS=meta-webindexer,claude-searchbot,duckassistbot,chatgpt-user,oai-searchbot
# Comma-separated UA fragments to hard block at edge (403).
HARD_BLOCK_AI_BOTS=gptbot,claudebot,claude-web,anthropic-ai,bytespider,ccbot,cohere-ai,perplexitybot,perplexity-user,amazonbot,amzn-searchbot,youbot,diffbot,meta-externalagent
# Secret Key used to authenticate with TollBit API
TOLLBIT_SECRET_KEY=your-tollbit-secret-key
